{
  "name": "video-recorder-studio",
  "version": "2.3.0",
  "main": "src/main/index.js",

  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "dev:renderer": "cd renderer && npm run dev",
    "dev:electron": "electron .",

    "build:renderer": "cd renderer && npm run build",
    "build": "npm run build:renderer",

    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",

    "release": "standard-version"
  },

  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "standard-version": "^9.5.0",
    "wait-on": "^7.2.0"
  },

  "dependencies": {
    "check-disk-space": "^3.4.0",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.3.0"
  },

  "build": {
    "appId": "com.internal.video-recorder-studio",
    "productName": "Video Recorder Studio",

    "publish": {
      "provider": "github",
      "owner": "RamnarayanMandal",
      "repo": "video-recorder-studio"
    },

    "directories": {
      "output": "dist"
    },

    "files": [
      "src/main/**/*",
      "renderer/dist/**/*",
      "node_modules/ffmpeg-static/**/*",
      "package.json"
    ],

    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**",
      "**/ffmpeg.exe",
      "**/ffmpeg",
      "**/*.dll"
    ],

    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "asInvoker"
    },

    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },

    "linux": {
      "target": "AppImage"
    }
  }
}